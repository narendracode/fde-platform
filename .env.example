# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=agri
POSTGRES_PASSWORD=agripass
POSTGRES_DB=agri_agent

# ── LangFlow ─────────────────────────────────────────────────────────────────
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=adminpass123

# ── API ──────────────────────────────────────────────────────────────────────
API_KEY=dev-secret-key-change-in-prod
LOG_LEVEL=info

# ── LLM Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Search (optional — agent uses mock if not set) ────────────────────────────
TAVILY_API_KEY=tvly-...

# ── LangSmith (optional — set LANGCHAIN_TRACING_V2=true to enable) ───────────
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=lsv2_...
LANGCHAIN_PROJECT=agri-agent-poc
