# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=agri
POSTGRES_PASSWORD=agripass
POSTGRES_DB=agri_agent

# ── LangFlow ─────────────────────────────────────────────────────────────────
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=adminpass123
# Stable secret for JWT signing — must not change between restarts or all
# existing sessions will be invalidated. Generate once with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
LANGFLOW_SECRET_KEY=change-this-to-a-long-random-string-before-going-to-prod

# ── API ──────────────────────────────────────────────────────────────────────
API_KEY=dev-secret-key-change-in-prod
LOG_LEVEL=info

# ── LLM Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key


# ── Search (optional — agent uses mock if not set) ────────────────────────────
TAVILY_API_KEY=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

# ── LangSmith (optional — set LANGCHAIN_TRACING_V2=true to enable) ───────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT="deep-research-agent"
