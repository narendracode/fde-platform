# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=fde
POSTGRES_PASSWORD=fdepass
POSTGRES_DB=fde_agent

# ── API ──────────────────────────────────────────────────────────────────────
API_KEY=dev-secret-key-change-in-prod
LOG_LEVEL=info

# ── UI Feature Flags ──────────────────────────────────────────────────────────
# Comma-separated list of companies whose pages appear in the sidebar.
# Valid values: sandhar, fundly   (empty = platform-only pages)
COMPANIES_TO_SHOW=sandhar,fundly

# ── LLM Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key


# ── Search (optional — agent uses mock if not set) ────────────────────────────
TAVILY_API_KEY=

# ── LangSmith (optional — set LANGCHAIN_TRACING_V2=true to enable) ───────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT="deep-research-agent"

LANGCHAIN_TRACING_V2=true
